{%- comment -%}
  Brand steps — canonical 4-step (or 3-step) icon-card grid.

  Single source of truth for the consumption-flow visual across
  homepage (/), lander (product.lander template), and the cómo-funciona
  page (/pages/que-es, /pages/como-funciona). Dark navy cards on
  secondary-navy background, green step numbers, flat monochrome Faena
  icons (step-icon-{world,glass,moon,sun}.svg).

  Usage:
    {%- assign step_blocks = section.blocks | where: 'type', 'step' -%}
    {% render 'brand-steps',
       blocks: step_blocks,
       label: section.settings.label,
       heading: section.settings.heading,
       footnote: section.settings.footnote
    %}

  Expected block shape:
    block.settings.number       (optional) — override for step number; defaults to forloop.index
    block.settings.title        (required) — step title
    block.settings.description  (optional) — small description below title
    block.settings.default_icon (optional) — 'world' | 'glass' | 'moon' | 'sun'
                                             auto-assigned by position when blank
    block.settings.icon         (optional) — image_picker override for custom SVG/PNG

  Params:
    blocks (required)    — pre-filtered array of step blocks (caller does `| where:`)
    label (optional)     — small green uppercase label above heading
    heading (optional)   — main heading text above cards
    footnote (optional)  — small text below cards
    id (optional)        — DOM id on the outer <section> (for anchor links like /#como-usarlo)
    section_bg (optional) — outer section background; default '#0A2A5E' (brand secondary navy)
    card_bg (optional)    — card background; default '#001D45' (brand primary navy)

  Icon auto-assignment (when block.settings.default_icon is blank):
    position 1 → world (Celebrate)
    position 2 → glass (Take capsules)
    position 3 → moon  (Sleep)
    position 4 → sun   (Wake up)
  For 3-step configs that skip "Sleep" per brand book, set default_icon: 'sun'
  explicitly on block 3.

  Source: Buenacopa brand guide. Assets: assets/step-icon-*.svg.
{%- endcomment -%}
{%- assign _section_bg = section_bg | default: '#0A2A5E' -%}
{%- assign _card_bg = card_bg | default: '#001D45' -%}
{%- assign _default_icons = 'world,glass,moon,sun' | split: ',' -%}

<section{% if id %} id="{{ id }}"{% endif %} class="overflow-hidden" style="padding: 4rem 0; background-color: {{ _section_bg }};">
  <div class="container-custom">

    {%- if label != blank -%}
      <p class="font-bold uppercase tracking-wider text-center" style="font-size: 11px; letter-spacing: 0.12em; margin-bottom: 10px; color: #00A33C;">{{ label }}</p>
    {%- endif -%}

    {%- if heading != blank -%}
      <h2 class="font-display font-black text-center" style="font-size: clamp(1.5rem, 5vw, 2.25rem); line-height: 1.15; margin: 0 auto 40px; max-width: 720px; color: #FFFFFF;">{{ heading }}</h2>
    {%- endif -%}

    {%- comment -%}
      Grid: stack on mobile (single column, 480px max), horizontal on desktop
      (one column per block, wider container). Uses --cols CSS var so each
      instance picks up its own block count without colliding when multiple
      brand-steps render on the same page.
    {%- endcomment -%}
    <style>
      .brand-steps-grid { display: grid; gap: 16px; grid-template-columns: 1fr; max-width: 480px; margin-left: auto; margin-right: auto; }
      @media (min-width: 768px) {
        .brand-steps-grid { grid-template-columns: repeat(var(--brand-steps-cols, 4), 1fr); max-width: 1100px; align-items: stretch; }
      }
    </style>
    <div class="brand-steps-grid" style="--brand-steps-cols: {{ blocks.size }};">
      {%- for block in blocks -%}
        <div
          class="relative"
          style="background-color: {{ _card_bg }}; border: 1px solid rgba(255,255,255,0.06); border-radius: 16px; padding: 28px 20px 26px;"
          {{ block.shopify_attributes }}
        >
          {%- comment -%}Green step number top-left{%- endcomment -%}
          <span class="font-display font-black" style="position: absolute; top: 14px; left: 20px; font-size: 28px; line-height: 1; color: #00A33C;">{{ block.settings.number | default: forloop.index }}</span>

          {%- comment -%}Centered icon{%- endcomment -%}
          <div class="flex justify-center" style="margin-top: 8px; margin-bottom: 18px;">
            {%- if block.settings.icon != blank -%}
              <img src="{{ block.settings.icon | image_url: width: 160 }}" alt="" width="80" height="80" loading="lazy" aria-hidden="true" style="height: 80px; width: auto;">
            {%- else -%}
              {%- assign icon_name = block.settings.default_icon -%}
              {%- if icon_name == blank -%}
                {%- assign icon_idx = forloop.index | minus: 1 -%}
                {%- if icon_idx < _default_icons.size -%}
                  {%- assign icon_name = _default_icons[icon_idx] -%}
                {%- endif -%}
              {%- endif -%}
              {%- if icon_name != blank -%}
                <img src="{{ 'step-icon-' | append: icon_name | append: '.svg' | asset_url }}" alt="" width="80" height="80" loading="lazy" aria-hidden="true" style="height: 80px; width: auto;">
              {%- endif -%}
            {%- endif -%}
          </div>

          {%- comment -%}Title{%- endcomment -%}
          <h3 class="font-display font-bold text-center" style="font-size: 15px; line-height: 1.3; color: #FFFFFF; margin: 0 auto; max-width: 240px;">{{ block.settings.title }}</h3>

          {%- comment -%}Optional description{%- endcomment -%}
          {%- if block.settings.description != blank -%}
            <p class="text-center" style="font-size: 13px; margin: 6px auto 0; line-height: 1.4; color: rgba(255,255,255,0.6); max-width: 240px;">{{ block.settings.description }}</p>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>

    {%- if footnote != blank -%}
      <p class="text-center mx-auto" style="max-width: 480px; margin-top: 28px; padding: 12px 18px; font-size: 12px; line-height: 1.5; color: rgba(255,255,255,0.55); background-color: rgba(255,255,255,0.04); border-radius: 10px;">{{ footnote }}</p>
    {%- endif -%}

  </div>
</section>
