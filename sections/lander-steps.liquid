{%- comment -%}
  Lander Steps — renders the canonical 4-step icon-card grid.
  All step-rendering logic lives in snippets/brand-steps.liquid.
{%- endcomment -%}

{%- assign step_blocks = section.blocks | where: 'type', 'step' -%}
{% render 'brand-steps',
  blocks: step_blocks,
  label: section.settings.label,
  heading: section.settings.heading,
  footnote: section.settings.footnote
%}

{% schema %}
{
  "name": "Lander Steps",
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "Section Label",
      "default": "CÓMO FUNCIONA"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Saber cuándo y cómo tomar Buenacopa hace toda la diferencia."
    },
    {
      "type": "textarea",
      "id": "footnote",
      "label": "Footnote (optional)"
    }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Step",
      "settings": [
        {
          "type": "text",
          "id": "number",
          "label": "Step Number",
          "default": "1"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title"
        },
        {
          "type": "text",
          "id": "description",
          "label": "Description"
        },
        {
          "type": "select",
          "id": "default_icon",
          "label": "Canonical icon",
          "options": [
            { "value": "", "label": "Auto (by step order)" },
            { "value": "world", "label": "Disco / world" },
            { "value": "glass", "label": "Capsule / glass" },
            { "value": "moon", "label": "Moon" },
            { "value": "sun", "label": "Sun" }
          ],
          "default": ""
        },
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Custom icon (overrides canonical)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Lander Steps",
      "blocks": [
        {
          "type": "step",
          "settings": {
            "number": "1",
            "title": "Celebra",
            "description": "Disfruta tu noche sin reservas"
          }
        },
        {
          "type": "step",
          "settings": {
            "number": "2",
            "title": "Toma tus 3 cápsulas",
            "description": "Con agua, después de tu última copa"
          }
        },
        {
          "type": "step",
          "settings": {
            "number": "3",
            "title": "Actúa mientras duermes",
            "description": "Buenacopa procesa el alcohol mientras descansas",
            "default_icon": "moon"
          }
        },
        {
          "type": "step",
          "settings": {
            "number": "4",
            "title": "Despierta y conquista",
            "description": "Tu mañana es tuya",
            "default_icon": "sun"
          }
        }
      ]
    }
  ]
}
{% endschema %}
