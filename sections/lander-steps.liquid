{%- comment -%}
  Lander Steps — Simplified 3-step vertical layout.
  Mobile-optimized, icon-based (not large images like how-it-works.liquid).
  "Three steps = low friction."
{%- endcomment -%}

<section class="overflow-hidden" style="padding: 3rem 0; background-color: #FAF7F2;">
  <div class="container-custom">

    {%- comment -%}Section label{%- endcomment -%}
    {% if section.settings.label != blank %}
      <p class="font-bold uppercase tracking-wider text-center" style="font-size: 11px; letter-spacing: 0.1em; margin-bottom: 6px; color: #00AB43;">
        {{ section.settings.label }}
      </p>
    {% endif %}

    <h2 class="font-display font-black text-center" style="font-size: clamp(1.5rem, 5vw, 2.25rem); line-height: 1.1; margin-bottom: 32px; color: #071D40;">
      {{ section.settings.heading | default: 'Tres pasos. Cero sacrificios.' }}
    </h2>

    {%- comment -%}Steps{%- endcomment -%}
    <div class="mx-auto" style="max-width: 420px;">
      {% for block in section.blocks %}
        {% if block.type == 'step' %}
          <div class="flex items-start gap-4" style="{% unless forloop.first %}margin-top: 24px;{% endunless %}" {{ block.shopify_attributes }}>
            {%- comment -%}Step number circle{%- endcomment -%}
            <div class="shrink-0 flex items-center justify-center rounded-full font-display font-black text-white" style="width: 40px; height: 40px; background-color: #071D40; font-size: 16px;">
              {{ block.settings.number | default: forloop.index }}
            </div>

            <div style="padding-top: 2px;">
              {%- comment -%}Optional icon{%- endcomment -%}
              {% if block.settings.icon %}
                <img
                  src="{{ block.settings.icon | image_url: width: 48 }}"
                  alt=""
                  class="mb-2"
                  width="24" height="24"
                  loading="lazy"
                  aria-hidden="true"
                >
              {% endif %}

              <h3 class="font-display font-bold" style="font-size: 17px; line-height: 1.2; color: #071D40;">
                {{ block.settings.title }}
              </h3>
              {% if block.settings.description != blank %}
                <p style="font-size: 14px; margin-top: 4px; line-height: 1.4; color: rgba(7,29,64,0.55);">
                  {{ block.settings.description }}
                </p>
              {% endif %}
            </div>
          </div>

          {%- comment -%}Connector line between steps{%- endcomment -%}
          {% unless forloop.last %}
            <div style="margin-left: 19px; width: 2px; height: 20px; background-color: rgba(7,29,64,0.1);"></div>
          {% endunless %}
        {% endif %}
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Lander Steps",
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "Section Label",
      "default": "CÓMO FUNCIONA"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Tres pasos. Cero sacrificios."
    }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Step",
      "settings": [
        {
          "type": "text",
          "id": "number",
          "label": "Step Number",
          "default": "1"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title"
        },
        {
          "type": "text",
          "id": "description",
          "label": "Description"
        },
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Icon (optional)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Lander Steps",
      "blocks": [
        {
          "type": "step",
          "settings": {
            "number": "1",
            "title": "Celebra",
            "description": "Disfruta tu noche sin reservas"
          }
        },
        {
          "type": "step",
          "settings": {
            "number": "2",
            "title": "Toma tus 3 cápsulas",
            "description": "Con agua, después de tu última copa"
          }
        },
        {
          "type": "step",
          "settings": {
            "number": "3",
            "title": "Despierta y conquista",
            "description": "Tu mañana es tuya"
          }
        }
      ]
    }
  ]
}
{% endschema %}
