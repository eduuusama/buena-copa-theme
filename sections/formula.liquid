<section id="formula" class="section-padding overflow-hidden relative">
  <!-- Background images - mobile vs desktop -->
  <div class="absolute inset-0 z-0">
    {% if section.settings.bg_mobile %}
      <img
        src="{{ section.settings.bg_mobile | image_url: width: 768 }}"
        srcset="{{ section.settings.bg_mobile | image_url: width: 480 }} 480w, {{ section.settings.bg_mobile | image_url: width: 768 }} 768w"
        sizes="100vw"
        alt="" class="w-full h-full object-cover md:hidden" loading="lazy" width="768" height="1024" decoding="async">
    {% else %}
      <img src="{{ 'formula-bg-new.jpeg' | asset_url }}" alt="" class="w-full h-full object-cover md:hidden" loading="lazy" width="768" height="1024" decoding="async">
    {% endif %}
    {% if section.settings.bg_desktop %}
      <img
        src="{{ section.settings.bg_desktop | image_url: width: 1200 }}"
        srcset="{{ section.settings.bg_desktop | image_url: width: 1200 }} 1200w, {{ section.settings.bg_desktop | image_url: width: 1920 }} 1920w"
        sizes="100vw"
        alt="" class="w-full h-full object-cover hidden md:block" loading="lazy" width="1920" height="1080" decoding="async">
    {% else %}
      <img src="{{ 'formula-bg-desktop-new.jpeg' | asset_url }}" alt="" class="w-full h-full object-cover hidden md:block" loading="lazy" width="1920" height="1080" decoding="async">
    {% endif %}
  </div>

  <div class="container-custom relative z-10">
    <div class="text-center mb-12 md:mb-16">
      <h2 class="text-3xl md:text-4xl lg:text-5xl font-display font-black text-foreground drop-shadow-lg">
        {{ section.settings.heading | default: 'La fórmula que previene la cruda' }}
      </h2>
    </div>

    <div class="grid md:grid-cols-2 gap-6 md:gap-8 max-w-4xl mx-auto">
      {% for block in section.blocks %}
        {% if block.type == 'ingredient' %}
          <div class="bg-background/80 backdrop-blur-md border border-white/10 rounded-2xl p-8 md:p-10 flex flex-col gap-5" {{ block.shopify_attributes }}>
            <div class="w-14 h-14 flex items-center justify-center">
              {% if block.settings.icon %}
                <img src="{{ block.settings.icon | image_url: width: 112 }}" alt="{{ block.settings.title }}" class="w-14 h-14 object-contain" width="56" height="56">
              {% endif %}
            </div>
            <div>
              <h3 class="text-2xl md:text-3xl font-display font-black text-accent">{{ block.settings.title }}</h3>
              {% if block.settings.subtitle %}
                <p class="text-muted-foreground text-sm font-medium mt-1">{{ block.settings.subtitle }}</p>
              {% endif %}
            </div>
            <p class="text-foreground/85 leading-relaxed">{{ block.settings.description }}</p>
          </div>
        {% endif %}
      {% endfor %}
    </div>

    <!-- Bottom tagline -->
    <div class="mt-12 md:mt-16 text-center max-w-2xl mx-auto">
      <div class="flex items-center justify-center gap-4 mb-6">
        <span class="h-px w-12 bg-accent/40"></span>
        <span class="w-2 h-2 rounded-full bg-accent"></span>
        <span class="h-px w-12 bg-accent/40"></span>
      </div>
      <p class="text-lg md:text-xl font-display font-bold text-foreground leading-relaxed drop-shadow-md">
        {{ section.settings.tagline | default: 'Doble ataque, una sola misión: Que la cruda no llegue, y amanezcas bien.' }}
      </p>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Formula",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "La fórmula que previene la cruda"
    },
    {
      "type": "text",
      "id": "tagline",
      "label": "Bottom Tagline",
      "default": "Doble ataque, una sola misión: Que la cruda no llegue, y amanezcas bien."
    },
    {
      "type": "image_picker",
      "id": "bg_mobile",
      "label": "Background Image (Mobile)"
    },
    {
      "type": "image_picker",
      "id": "bg_desktop",
      "label": "Background Image (Desktop)"
    }
  ],
  "blocks": [
    {
      "type": "ingredient",
      "name": "Ingredient Card",
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Icon"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title"
        },
        {
          "type": "text",
          "id": "subtitle",
          "label": "Subtitle"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Formula",
      "blocks": [
        {
          "type": "ingredient",
          "settings": {
            "title": "DHM",
            "subtitle": "Dihidromiricetina",
            "description": "Acelera el metabolismo del alcohol desde el cerebro. Reduce la ansiedad post-fiesta. Protege tu hígado."
          }
        },
        {
          "type": "ingredient",
          "settings": {
            "title": "L-Cisteína",
            "description": "Neutraliza toxinas. Refuerza tus defensas. Disminuye náuseas y dolor de cabeza."
          }
        }
      ]
    }
  ]
}
{% endschema %}
