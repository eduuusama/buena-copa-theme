<footer class="bg-secondary/50 border-t border-border overflow-hidden">
  <div class="container-custom py-12 md:py-16">
    <div class="grid md:grid-cols-4 gap-8">
      <!-- Brand -->
      <div class="md:col-span-1">
        <a href="/" class="block mb-3">
          {% if section.settings.logo %}
            <img src="{{ section.settings.logo | image_url: width: 200 }}" alt="{{ shop.name }}" class="h-7 w-auto" width="100" height="28">
          {% else %}
            <img src="{{ 'logo-offwhite.png' | asset_url }}" alt="{{ shop.name }}" class="h-7 w-auto" width="100" height="28">
          {% endif %}
        </a>
        <p class="text-muted-foreground text-sm leading-relaxed">
          {{ section.settings.tagline | default: 'Bienestar post-fiesta. Celebra hoy, conquista mañana.' }}
        </p>
        <div class="flex gap-3 mt-4">
          {% if section.settings.instagram_url %}
            <a href="{{ section.settings.instagram_url }}" target="_blank" rel="noopener noreferrer" aria-label="Instagram" class="w-9 h-9 rounded-full bg-white/5 border border-border flex items-center justify-center hover:border-accent transition-colors">
              {% render 'icon-instagram' %}
            </a>
          {% endif %}
          {% if section.settings.facebook_url %}
            <a href="{{ section.settings.facebook_url }}" target="_blank" rel="noopener noreferrer" aria-label="Facebook" class="w-9 h-9 rounded-full bg-white/5 border border-border flex items-center justify-center hover:border-accent transition-colors">
              {% render 'icon-facebook' %}
            </a>
          {% endif %}
        </div>
      </div>

      <!-- Link Groups -->
      {% for block in section.blocks %}
        {% if block.type == 'link_group' %}
          <div {{ block.shopify_attributes }}>
            <h3 class="font-bold text-foreground text-sm mb-4">{{ block.settings.title }}</h3>
            {% if block.settings.menu != blank %}
              <ul class="space-y-2 text-sm">
                {% for link in linklists[block.settings.menu].links %}
                  <li>
                    <a href="{{ link.url }}" class="text-muted-foreground hover:text-foreground transition-colors">
                      {{ link.title }}
                    </a>
                  </li>
                {% endfor %}
              </ul>
            {% endif %}
          </div>
        {% endif %}
      {% endfor %}
    </div>

    <div class="border-t border-border mt-10 pt-6 text-center">
      <p class="text-muted-foreground text-xs">
        &copy; {{ 'now' | date: '%Y' }} {{ shop.name }}. Todos los derechos reservados. Este producto no está destinado a diagnosticar, tratar, curar o prevenir ninguna enfermedad.
      </p>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo"
    },
    {
      "type": "text",
      "id": "tagline",
      "label": "Tagline",
      "default": "Bienestar post-fiesta. Celebra hoy, conquista mañana."
    },
    {
      "type": "url",
      "id": "instagram_url",
      "label": "Instagram URL"
    },
    {
      "type": "url",
      "id": "facebook_url",
      "label": "Facebook URL"
    }
  ],
  "blocks": [
    {
      "type": "link_group",
      "name": "Link Group",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title"
        },
        {
          "type": "link_list",
          "id": "menu",
          "label": "Menu"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Footer",
      "blocks": [
        { "type": "link_group", "settings": { "title": "Producto" } },
        { "type": "link_group", "settings": { "title": "Soporte" } },
        { "type": "link_group", "settings": { "title": "Legal" } }
      ]
    }
  ]
}
{% endschema %}
