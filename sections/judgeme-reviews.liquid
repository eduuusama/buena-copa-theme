{%- assign current_product = product | default: section.settings.product -%}

<section class="section-padding bg-secondary overflow-hidden" id="reviews">
  <div class="container-custom">
    <h2 class="text-3xl md:text-4xl font-display font-black text-foreground text-center mb-10">
      {{ section.settings.heading | default: 'Reseñas de nuestros clientes' }}
    </h2>

    {%- comment -%}Judge.me Review Widget — renders via Judge.me JS{%- endcomment -%}
    <div
      class="jdgm-widget jdgm-review-widget"
      data-id="{{ current_product.id }}"
      data-product-title="{{ current_product.title | escape }}"
    ></div>
  </div>
</section>

{% schema %}
{
  "name": "Judge.me Reviews",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Reseñas de nuestros clientes"
    },
    {
      "type": "product",
      "id": "product",
      "label": "Product (optional — auto-detects on product pages)"
    }
  ],
  "presets": [
    {
      "name": "Judge.me Reviews"
    }
  ]
}
{% endschema %}
