{%- comment -%}
  How It Works — homepage step section. Renders the canonical icon-card
  grid via snippets/brand-steps.liquid. The legacy `image` field in the
  step block schema is deprecated (still accepted for back-compat but
  not rendered) — the visual moved from photo-timeline to icon cards.
{%- endcomment -%}

{%- assign step_blocks = section.blocks | where: 'type', 'step' -%}
{% render 'brand-steps',
  blocks: step_blocks,
  heading: section.settings.heading,
  id: 'como-usarlo'
%}

{% schema %}
{
  "name": "How It Works",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Tu ritual en 3 pasos"
    }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Step",
      "settings": [
        {
          "type": "text",
          "id": "number",
          "label": "Step Number",
          "default": "01"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description"
        },
        {
          "type": "select",
          "id": "default_icon",
          "label": "Canonical icon",
          "options": [
            { "value": "", "label": "Auto (by step order)" },
            { "value": "world", "label": "Disco / world" },
            { "value": "glass", "label": "Capsule / glass" },
            { "value": "moon", "label": "Moon" },
            { "value": "sun", "label": "Sun" }
          ],
          "default": "",
          "info": "Brand book: 3-step configs should use world → glass → sun (skip moon)."
        },
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Custom icon (overrides canonical)"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Step Image (deprecated — no longer rendered)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "How It Works",
      "blocks": [
        {
          "type": "step",
          "settings": {
            "number": "01",
            "title": "Celebra tu noche",
            "description": "Disfruta de forma responsable. Buenacopa está diseñado para acompañar tus mejores noches."
          }
        },
        {
          "type": "step",
          "settings": {
            "number": "02",
            "title": "Toma tus 3 cápsulas antes de dormir",
            "description": "Con un vaso de agua, después de tu última copa. Buenacopa actúa mientras duermes."
          }
        },
        {
          "type": "step",
          "settings": {
            "number": "03",
            "title": "Despierta y conquista tu día",
            "description": "Sin cruda, sin náuseas, sin dolor de cabeza. Tu mañana es tuya.",
            "default_icon": "sun"
          }
        }
      ]
    }
  ]
}
{% endschema %}
