<!DOCTYPE html>
<html lang="es">
<head>
 {%- if content_for_header contains 'tapita-seo-script-tags' -%}{%- include 'tapita-seo-schema' -%}{%- endif -%}

  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ page_title }}{% unless page_title contains shop.name %} – {{ shop.name }}{% endunless %}</title>
  {% if page_description %}
    <meta name="description" content="{{ page_description | escape }}">
  {% endif %}

  {{ content_for_header }}

  <!-- Preconnect -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link rel="dns-prefetch" href="https://cdn.judge.me">

  <!-- Preload LCP hero image -->
  <link rel="preload" as="image" href="{{ 'hero-sachet.jpg' | asset_url }}" fetchpriority="high">

  <!-- Fonts (non-render-blocking) -->
  <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&family=Nunito:wght@400;700;800;900&display=swap">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&family=Nunito:wght@400;700;800;900&display=swap" rel="stylesheet" media="print" onload="this.media='all'">
  <noscript><link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&family=Nunito:wght@400;700;800;900&display=swap" rel="stylesheet"></noscript>

  <!-- Tailwind (compiled & purged — replaces CDN) -->
  {{ 'tailwind.min.css' | asset_url | stylesheet_tag }}

  <!-- Theme CSS -->
  {{ 'theme.min.css' | asset_url | stylesheet_tag }}

  {% render 'meta-tags', page_description: page_description, page_title: page_title  %}

  <!-- Organization JSON-LD -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": {{ shop.name | json }},
    "url": "{{ shop.url }}",
    "logo": "https:{{ 'logo.png' | asset_url }}",
    "description": {{ shop.description | json }},
    "sameAs": [
      {% if settings.social_instagram_link != blank %}"{{ settings.social_instagram_link }}"{% endif %}
      {% if settings.social_facebook_link != blank %},{{ settings.social_facebook_link | json }}{% endif %}
      {% if settings.social_tiktok_link != blank %},{{ settings.social_tiktok_link | json }}{% endif %}
      {% if settings.social_twitter_link != blank %},{{ settings.social_twitter_link | json }}{% endif %}
      {% if settings.social_youtube_link != blank %},{{ settings.social_youtube_link | json }}{% endif %}
    ]
  }
  </script>
</head>
<body class="min-h-screen bg-background text-foreground font-sans antialiased">
  {% section 'header' %}

  <main>
    {{ content_for_layout }}
  </main>

  {% section 'footer' %}

  {% render 'cart-drawer' %}

  <script src="{{ 'theme.min.js' | asset_url }}" defer></script>
  <script src="{{ 'cart-drawer.min.js' | asset_url }}" defer></script>
  <script src="{{ 'product-form.min.js' | asset_url }}" defer></script>
  <script src="{{ 'video-section.min.js' | asset_url }}" defer></script>
</body>
</html>
